{
    "name": "macro",
    "version": "0.1.0",
    "description": "System macro actions — keystrokes, hotkeys, text input, and app launching",
    "actions": [
        "macro.hotkey",
        "macro.type",
        "macro.launch",
        "macro.keypress"
    ],
    "actionDetails": {
        "macro.hotkey": {
            "description": "Press a key combination",
            "params": {
                "keys": {
                    "type": "string",
                    "description": "Key combo (separated by +)",
                    "placeholder": "ctrl+shift+s",
                    "required": true
                }
            }
        },
        "macro.keypress": {
            "description": "Press a single key",
            "params": {
                "key": {
                    "type": "string",
                    "description": "Key name or character",
                    "placeholder": "enter, escape, f5, a",
                    "required": true
                }
            }
        },
        "macro.type": {
            "description": "Type a text string via SendKeys",
            "params": {
                "text": {
                    "type": "textarea",
                    "description": "Text to type",
                    "placeholder": "Hello world",
                    "rows": 3,
                    "required": true
                }
            }
        },
        "macro.launch": {
            "description": "Launch an app, URL, or file",
            "params": {
                "target": {
                    "type": "string",
                    "description": "App name, URL, or file path",
                    "placeholder": "notepad, https://github.com, C:\\file.txt",
                    "required": true
                }
            }
        }
    }
}
