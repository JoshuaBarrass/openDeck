{
    "name": "obs-control",
    "version": "0.2.0",
    "description": "OBS Studio integration via obs-websocket-js",
    "actions": [
        "obs.startStreaming",
        "obs.stopStreaming",
        "obs.startRecording",
        "obs.stopRecording",
        "obs.toggleRecording",
        "obs.toggleMute",
        "obs.setVolume",
        "obs.switchScene",
        "obs.toggleSource"
    ],
    "actionDetails": {
        "obs.startStreaming": {
            "description": "Start streaming"
        },
        "obs.stopStreaming": {
            "description": "Stop streaming"
        },
        "obs.startRecording": {
            "description": "Start recording"
        },
        "obs.stopRecording": {
            "description": "Stop recording"
        },
        "obs.toggleRecording": {
            "description": "Toggle recording on/off"
        },
        "obs.toggleMute": {
            "description": "Toggle mute on an audio source",
            "params": {
                "source": {
                    "type": "string",
                    "description": "Audio source name",
                    "placeholder": "Mic/Aux",
                    "required": true
                }
            }
        },
        "obs.setVolume": {
            "description": "Set volume on an audio source",
            "params": {
                "source": {
                    "type": "string",
                    "description": "Audio source name",
                    "placeholder": "Mic/Aux",
                    "required": true
                },
                "volume": {
                    "type": "number",
                    "description": "Volume in dB (or 0.0–1.0 if useMul is on)",
                    "placeholder": "-10",
                    "step": 0.1,
                    "required": true
                },
                "useMul": {
                    "type": "boolean",
                    "description": "Treat volume as 0.0–1.0 multiplier instead of dB",
                    "default": false
                }
            }
        },
        "obs.switchScene": {
            "description": "Switch to a scene",
            "params": {
                "scene": {
                    "type": "string",
                    "description": "Scene name",
                    "placeholder": "Main Camera",
                    "required": true
                }
            }
        },
        "obs.toggleSource": {
            "description": "Toggle visibility of a source in a scene",
            "params": {
                "scene": {
                    "type": "string",
                    "description": "Scene name containing the source",
                    "placeholder": "Main Camera",
                    "required": true
                },
                "source": {
                    "type": "string",
                    "description": "Source name to toggle",
                    "placeholder": "Webcam",
                    "required": true
                }
            }
        }
    }
}
