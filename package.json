{
    "name": "opendeck",
    "version": "0.1.0",
    "description": "Open-source web-based stream deck alternative",
    "main": "dist/electron/electron/main.js",
    "scripts": {
        "build:electron": "tsc -p tsconfig.electron.json",
        "build:renderer": "vite build",
        "build": "npm run build:electron && npm run build:renderer",
        "dev:electron": "tsc -p tsconfig.electron.json --watch",
        "dev:renderer": "vite",
        "dev": "concurrently \"npm run dev:electron\" \"npm run dev:renderer\" \"wait-on http://localhost:5173 dist/electron/electron/main.js && electron .\"",
        "start": "electron ."
    },
    "keywords": [
        "stream-deck",
        "macro",
        "control-surface",
        "electron"
    ],
    "license": "MIT",
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@types/ws": "^8.5.10",
        "@vitejs/plugin-react": "^4.2.1",
        "concurrently": "^8.2.2",
        "electron": "^28.1.4",
        "typescript": "^5.3.3",
        "vite": "^5.0.12",
        "wait-on": "^7.2.0"
    },
    "dependencies": {
        "express": "^4.18.2",
        "obs-websocket-js": "^5.0.7",
        "qrcode.react": "^4.2.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "ws": "^8.16.0"
    }
}
